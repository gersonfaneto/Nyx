#ifndef __FUNCTION__
  #define __FUNCTION__ __func__
#endif // ! __FUNCTION__

#ifdef __DEBUG__
  #define __ASSERT__(condition, format, ...)     \
    if ((condition)) return;                     \
                                                 \
    fprintf(stderr, format "\n", ##__VA_ARGS__); \
                                                 \
    abort();                                     \

  #define __TODO__(...) __ASSERT__(0, "TODO :: `%s` at `%s:%d`", __FUNCTION__, __FILE__, __LINE__)
#else
    #define __ASSERT__(...) ((void) 0)
    #define __TODO__(...) ((void) 0)
#endif // ! __DEBUG__

